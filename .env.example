# ============================================================
# .env.example — скопируйте в .env и заполните реальными значениями
# НИКОГДА не коммитьте .env в git
# ============================================================

# --- База данных PostgreSQL ---
# Локально через docker compose — оставьте как есть.
DATABASE_URL=postgresql+asyncpg://idbjj:idbjj@postgres:5432/idbjj

# --- MAX Bot API (бот работает напрямую, без Salebot) ---
# Токен бота от @MasterBot в MAX. Для постинга в канал бот должен быть его админом.
MAX_BOT_TOKEN=
MAX_CHANNEL_ID=
MAX_API_BASE=https://botapi.max.ru

# Публичный HTTPS-адрес сервиса (на VPS) — для регистрации вебхука на старте.
# Напр.: https://idbjj.example.ru
PUBLIC_BASE_URL=

# Секрет в URL входящего вебхука: https://<PUBLIC_BASE_URL>/webhooks/max/<секрет>
# Длинная случайная строка: openssl rand -hex 32
MAX_WEBHOOK_SECRET=

# --- Telegram Bot API (второй канал; тот же сценарий + проактивные рассылки) ---
# Токен бота от @BotFather. Webhook: https://<PUBLIC_BASE_URL>/webhooks/telegram/<секрет>
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Тренер — куда приходят заявки из «Связаться с тренером».
# trainer_channel: max | telegram; trainer_chat_id — id тренера в этом канале.
# Узнать id: написать боту от имени тренера, id появится в логах апдейта. Пусто — без уведомлений.
TRAINER_CHANNEL=max
TRAINER_CHAT_ID=

# --- Админ-панель (HTTP Basic) ---
# Дашборд, лиды, рассылки, переписка. Если пароль пуст — панель закрыта (503).
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Ссылки на ботов для лендинга (кнопки «Открыть в MAX / Telegram») ---
MAX_BOT_URL=
TELEGRAM_BOT_URL=https://t.me/your_bot

# --- LLM-провайдер для 3 AI-ассистентов (Тренер / Энциклопедия / Диетолог) ---
# openai  → напрямую ChatGPT (OPENAI_API_KEY, OPENAI_MODEL)
# openrouter → через OpenRouter (OPENROUTER_API_KEY, OPENROUTER_MODEL)
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Через запятую — резервные модели, если основная вернёт 429/5xx
OPENROUTER_FALLBACKS=

# GigaChat (Сбер) — оплата рублями, freemium 1M токенов/мес. Если ключ задан —
# работает авто-фоллбэком к OpenAI (бот не падает, если OpenAI кончился/упал).
# Чтобы сделать GigaChat основным — поставь LLM_PROVIDER=gigachat.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat

# --- Прочее ---
TZ=Europe/Moscow
